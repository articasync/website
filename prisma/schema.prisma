generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Connection string (used for the app, usually pooled)
  directUrl = env("DIRECT_URL") // Direct connection for migrations (e.g., Prisma db push)
}

// Global settings for the application
model Setting {
  id    String @id @default(cuid())
  key   String @unique // e.g., "notification_email"
  value String
}

// Restaurants to be monitored
model Restaurant {
  id              Int      @id // This will be the Resy Venue ID
  slug            String   @unique
  name            String
  alerts          Alert[]
  lastCheckedAt   DateTime?
  lastCheckStatus String?
}

// Specific email alerts for a restaurant
model Alert {
  id           String     @id @default(cuid())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  email           String
  createdAt       DateTime   @default(now())
  lastEmailSentAt DateTime?
  lastEmailStatus String? // "success" or "failed"

  @@unique([restaurantId, email])
}

// To track which notifications have already been sent to avoid spam
model NotifiedSlot {
  id            String   @id @default(cuid())
  restaurantId  Int
  slotDateTime  DateTime // e.g., 2024-08-15T19:00:00Z
  partySize     Int
  createdAt     DateTime @default(now())

  @@unique([restaurantId, slotDateTime, partySize])
}
// Daily Fitness Data
model FitnessLog {
  id                    String   @id @default(cuid())
  date                  DateTime @unique @default(now())
  
  // Garmin Data
  rhr                   Int?
  hrv                   Int?
  sleepScore            Int?
  sleepHours            Float?
  trainingReadiness     Int?
  menstrualCyclePhase   String?

  // Gemini / Strava Data
  predictedFtp          Int?
  predictedFtpTrend     String?
  predictedVo2          Float?
  predictedVo2Trend     String?
  ftpToday              Int?
  idealWorkout          String?
  
  createdAt             DateTime @default(now())
}
